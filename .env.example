# Copy to .env and adjust for local development.
SECRET_KEY=dev-only-task-scheduler-secret
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=postgres://scheduler:scheduler@localhost:5432/task_scheduler
REDIS_URL=redis://localhost:6379/0
APP_TIMEZONE=UTC
SCHEDULER_TICK_SECONDS=5
WORKER_COUNT=2
EXECUTOR_BACKEND=subprocess
DEFAULT_TIMEOUT_SECONDS=30
DEFAULT_MAX_ATTEMPTS=3
DEFAULT_RETRY_BACKOFF_SECONDS=10
RETENTION_DAYS=30
RETENTION_COUNT=500
EVENT_RETENTION_DAYS=30
ALERT_MODE=web
LEASE_SECONDS=120
LEASE_BUFFER_SECONDS=30
MISFIRE_CATCH_UP_CAP=50
PRUNE_HISTORY_EVERY_N_TICKS=720
WEBUI_AUTH=1
WEBUI_PUBLIC_READ=1
SCHEDULER_CLI_SECRET=
HEARTBEAT_PRUNE_SECONDS=86400
READYZ_REQUIRE_HEARTBEATS=0
READYZ_REQUIRE_WORKER_HEARTBEAT=0
READYZ_HEARTBEAT_MAX_AGE_SECONDS=300
SESSION_COOKIE_AGE=
CSRF_TRUSTED_ORIGINS=
USE_X_FORWARDED_PROTO=0
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
SECURE_COOKIES=0
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin
DEV_ADMIN_EMAIL=admin@example.com
